{
  "eval_set_id": "learning_content_tests",
  "name": "LearningContent_Agent Tool Trajectory Tests",
  "description": "Validates LearningContent_Agent calls the right tools for Q&A, summaries, and flashcards",
  "eval_cases": [
    {
      "eval_id": "ask_question",
      "conversation": [
        {
          "invocation_id": "inv_1",
          "user_content": {
            "parts": [{ "text": "What is gradient descent according to my Machine Learning notes?" }]
          },
          "final_response": {
            "role": "model",
            "parts": [{ "text": "Based on your Machine Learning notes, gradient descent is an optimization algorithm used to minimize the loss function." }]
          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "transfer_to_agent", "args": { "agent_name": "LearningContent_Agent" } },
              { "name": "ask_question", "args": { "question": "What is gradient descent", "document_name": "Machine Learning notes" } }
            ]
          }
        }
      ],
      "session_input": {
        "app_name": "LMS_Project_V2",
        "user_id": "eval_user",
        "state": { "current_user_id": "eval_user" }
      }
    },
