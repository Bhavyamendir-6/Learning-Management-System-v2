{
  "eval_set_id": "quiz_history_tests",
  "name": "Quiz_Historian Tool Trajectory Tests",
  "description": "Validates Quiz_Historian calls the right tools for quiz history and stats",
  "eval_cases": [
    {
      "eval_id": "view_quiz_history",
      "conversation": [
        {
          "invocation_id": "inv_1",
          "user_content": {
            "parts": [{ "text": "Show me all my past quiz results" }]
          },
          "final_response": {
            "role": "model",
            "parts": [{ "text": "Here is your quiz history." }]
          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "transfer_to_agent", "args": { "agent_name": "Quiz_Historian" } },
              { "name": "quiz_history", "args": {} }
            ]
          }
        }
      ],
      "session_input": {
        "app_name": "LMS_Project_V2",
        "user_id": "eval_user",
        "state": { "current_user_id": "eval_user" }
      }
    },
    {
      "eval_id": "document_stats",
      "conversation": [
        {
          "invocation_id": "inv_1",
          "user_content": {
            "parts": [{ "text": "How did I perform on quizzes from my Machine Learning notes?" }]
          },
          "final_response": {
            "role": "model",
            "parts": [{ "text": "Here are your quiz statistics for Machine Learning notes." }]
          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "transfer_to_agent", "args": { "agent_name": "Quiz_Historian" } },
              { "name": "document_stats", "args": { "document_name": "Machine Learning notes" } }
            ]
          }
        }
      ],
      "session_input": {
        "app_name": "LMS_Project_V2",
        "user_id": "eval_user",
        "state": { "current_user_id": "eval_user" }
      }
    }
  ]
}
