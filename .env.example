# ── Google AI ──────────────────────────────────────────────────────────────
# Your Google Gemini API key.
# Get it from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash

# ── Database ────────────────────────────────────────────────────────────────
# Primary Postgres database for Users, Chats, Sessions, and Notes
# Get a free PostgreSQL database from https://neon.tech
POSTGRES_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# ── JWT Authentication ──────────────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here

# JWT signing algorithm (HS256 is recommended for symmetric secrets)
JWT_ALGORITHM=HS256

# How many hours a JWT token remains valid before the user must log in again.
JWT_EXPIRY_HOURS=24
